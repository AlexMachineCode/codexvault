// prisma:ignoreDeprecations
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Content {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  effect      String?
  type        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
